PROXMOX_HOST=127.0.0.1
PROXMOX_USER=root@pam
# You can generate a token in Proxmox Datacenter -> Permissions -> API Tokens
PROXMOX_TOKEN_ID=autoscaler
PROXMOX_TOKEN_SECRET=your-secret-uuid
NODE_NAME=pve

# System limits: Keep total allocation below this percentage so other VMs/LXCs have overhead
# NOTE: The autoscaler hardcodes an absolute maximum of 95.0% to prevent hypervisor crashes.
MAX_HOST_CPU_ALLOCATION_PERCENT=85
MAX_HOST_RAM_ALLOCATION_PERCENT=85

# Training Configuration
# How many days of Proxmox historical data the XGBoost model learns from overnight.
TRAINING_DAYS_LOOKBACK=7

# LXC & VM Config Baselines (Optional)
# The system stores these in a local database (autoscaler.db) to persist across reboots.
# Any Container or VM NOT listed here will be automatically discovered and assigned a dynamic baseline.
# Format: LXC_<ID> or VM_<ID> = min_cpu, min_ram_mb, max_cpu, max_ram_mb
LXC_100=1, 512, 4, 4096
VM_101=2, 1024, 8, 8192

# Excluded Containers & VMs (Optional)
# A comma-separated list of IDs that the autoscaler should completely ignore from auto-discovery.
EXCLUDED_LXCS=105, 110
EXCLUDED_VMS=102, 103
